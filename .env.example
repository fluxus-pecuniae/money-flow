APP_NAME=money-flow
APP_ENV=dev
APP_DEBUG=true
APP_API_HOST=0.0.0.0
APP_API_PORT=8000

DB_HOST=postgres
DB_PORT=5432
DB_NAME=money_flow
DB_USER=money_flow
DB_PASSWORD=money_flow
DB_ECHO=false

REDIS_ENABLED=false
REDIS_URL=redis://redis:6379/0

LOG_LEVEL=INFO
LOG_JSON=true

EXCHANGE_NAME=hyperliquid
EXCHANGE_VENUE=hyperliquid
EXCHANGE_USE_TESTNET=true
EXCHANGE_API_BASE_URL=https://api.hyperliquid.xyz
EXCHANGE_WS_BASE_URL=wss://api.hyperliquid.xyz/ws
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_SIGNING_PRIVATE_KEY=
EXCHANGE_ACCOUNT_ADDRESS=
EXCHANGE_ACCOUNT_LABEL=primary
# Reference labels only. These are not treated as raw secret material.
EXCHANGE_CREDENTIALS_REF=
EXCHANGE_WALLET_REF=
EXCHANGE_DEX_NAME=
EXCHANGE_REQUEST_TIMEOUT_SECONDS=10
EXCHANGE_ALLOW_LIVE_MODE_WITHOUT_API_KEY=false
EXCHANGE_UNIVERSE_INCLUDE_STANDARD_PERP=true
EXCHANGE_UNIVERSE_INCLUDE_BUILDER_DEPLOYED_IN_CATALOG=true
EXCHANGE_UNIVERSE_ALLOW_BUILDER_DEPLOYED_FOR_STRATEGY=false
EXCHANGE_UNIVERSE_ALLOW_BUILDER_DEPLOYED_FOR_TRADING=false
HYPERLIQUID_READ_ONLY_MODE=true
HYPERLIQUID_DRY_RUN_MODE=true
HYPERLIQUID_SUBMISSION_ENABLED=false
HYPERLIQUID_SUBMISSION_AUTHORIZED=false
# UAT3.0.5 sandbox/testnet private read-only verification only.
# Leave blank unless a phase explicitly approves sandbox/testnet private
# read-only account-state/drawdown verification. Never commit real values.
HYPERLIQUID_UAT_SANDBOX_PRIVATE_KEY=
HYPERLIQUID_UAT_SANDBOX_ACCOUNT=
HYPERLIQUID_UAT_SANDBOX_BASE_URL=https://api.hyperliquid-testnet.xyz

# Current integrated venues span two honest maturity branches:
# - execution-preparable with account/private-state inspection and prepared-order preview/preflight
# - submission-capable with explicit account-targeted submit-path implementation
# Live submission still stays disabled by default and requires both per-venue
# enablement and explicit account/environment authorization.
ASTER_ENABLED=true
ASTER_READ_ONLY_MODE=true
ASTER_DRY_RUN_MODE=true
ASTER_SUBMISSION_ENABLED=false
ASTER_USE_TESTNET=false
ASTER_USE_DEMO_MODE=false
ASTER_API_BASE_URL=https://fapi.asterdex.com
ASTER_WS_BASE_URL=
ASTER_ACCOUNT_IDENTIFIER=
ASTER_ACCOUNT_LABEL=
ASTER_CREDENTIALS_REF=
ASTER_API_KEY=
ASTER_API_SECRET=
ASTER_SUBMISSION_AUTHORIZED=false

OKX_ENABLED=true
OKX_READ_ONLY_MODE=true
OKX_DRY_RUN_MODE=true
OKX_SUBMISSION_ENABLED=false
OKX_USE_TESTNET=false
OKX_USE_DEMO_MODE=true
OKX_API_BASE_URL=https://www.okx.com
OKX_WS_BASE_URL=wss://ws.okx.com:8443/ws/v5/public
OKX_ACCOUNT_IDENTIFIER=
OKX_ACCOUNT_LABEL=
OKX_SUBACCOUNT_LABEL=
OKX_CREDENTIALS_REF=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_SUBMISSION_AUTHORIZED=false

COINBASE_ADVANCED_ENABLED=true
COINBASE_ADVANCED_READ_ONLY_MODE=true
COINBASE_ADVANCED_DRY_RUN_MODE=true
COINBASE_ADVANCED_SUBMISSION_ENABLED=false
COINBASE_ADVANCED_USE_TESTNET=false
COINBASE_ADVANCED_USE_DEMO_MODE=false
COINBASE_ADVANCED_API_BASE_URL=https://api.coinbase.com
COINBASE_ADVANCED_WS_BASE_URL=wss://advanced-trade-ws.coinbase.com
COINBASE_ADVANCED_ACCOUNT_IDENTIFIER=
COINBASE_ADVANCED_ACCOUNT_LABEL=
# Reference label only; actual JWT material must be supplied explicitly.
COINBASE_ADVANCED_CREDENTIALS_REF=
COINBASE_ADVANCED_API_KEY=
COINBASE_ADVANCED_API_SECRET=
COINBASE_ADVANCED_JWT_KEY_NAME=
COINBASE_ADVANCED_JWT_PRIVATE_KEY_PEM=
COINBASE_ADVANCED_SUBMISSION_AUTHORIZED=false

BINANCE_ENABLED=true
BINANCE_READ_ONLY_MODE=true
BINANCE_DRY_RUN_MODE=true
BINANCE_SUBMISSION_ENABLED=false
BINANCE_USE_TESTNET=false
BINANCE_USE_DEMO_MODE=false
BINANCE_API_BASE_URL=https://api.binance.com
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443/ws
BINANCE_ACCOUNT_IDENTIFIER=
BINANCE_ACCOUNT_LABEL=
BINANCE_SUBACCOUNT_LABEL=
BINANCE_CREDENTIALS_REF=
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_SUBMISSION_AUTHORIZED=false

KRAKEN_ENABLED=true
KRAKEN_READ_ONLY_MODE=true
KRAKEN_DRY_RUN_MODE=true
KRAKEN_SUBMISSION_ENABLED=false
KRAKEN_USE_TESTNET=false
KRAKEN_USE_DEMO_MODE=false
KRAKEN_API_BASE_URL=https://api.kraken.com
KRAKEN_WS_BASE_URL=wss://ws.kraken.com
KRAKEN_ACCOUNT_IDENTIFIER=
KRAKEN_ACCOUNT_LABEL=
KRAKEN_SUBACCOUNT_LABEL=
KRAKEN_CREDENTIALS_REF=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_SUBMISSION_AUTHORIZED=false

# Runtime selection is mandate-first. ACTIVE_ACCOUNT_KEY is optional and is used
# only as a focused account selector for bootstrap/inspection convenience.
ACTIVE_CLIENT_KEY=default_client
ACTIVE_ACCOUNT_KEY=
ACTIVE_MANDATE_KEY=

# Planning/source policy is mandate-owned. Today one mandate uses one active
# source venue for signal/planning truth, while future routing may still choose
# among many eligible bindings/accounts later.
MANDATE_MARKET_DATA_SOURCE_MODE=single_venue
MANDATE_MARKET_DATA_SOURCE_VENUE=hyperliquid
MANDATE_MARKET_DATA_SOURCE_MARKET_TYPE=
MANDATE_MARKET_DATA_SOURCE_PRODUCT_TYPE=
MANDATE_INSTRUMENT_RESOLUTION_MODE=canonical_symbol_if_unambiguous

RISK_GLOBAL_MAX_GROSS_EXPOSURE_PCT=1.00
RISK_GLOBAL_MAX_ACCOUNT_DRAWDOWN_PCT=0.15
RISK_GLOBAL_MAX_SYMBOL_CONCENTRATION_PCT=0.25
RISK_BINDING_REDUCE_FRACTION=0.5
RISK_TRADING_ENABLED=true
RISK_KILL_SWITCH_ENABLED=true
RISK_STACKING_POLICY=net_limit
RISK_REJECT_ON_SOURCE_POLICY_RUNTIME_MISMATCH=true

EXECUTION_DEFAULT_ORDER_TTL_SECONDS=30
EXECUTION_MAX_SLIPPAGE_BPS=10
EXECUTION_DRY_RUN=true
EXECUTION_LIVE_SUBMISSION_PHASE_ENABLED=false
# Separate Phase 5.4 gate for explicit routed child-intent submission.
# This does not enable auto-submit, best-binding selection, fanout, CBBO,
# target reselection, or smart routing.
EXECUTION_ROUTED_SUBMISSION_PHASE_ENABLED=false
EXECUTION_REQUIRE_PRIVATE_STATE_FOR_SUBMISSION_READINESS=true

ALERTS_ENABLED=false
ALERTS_DEFAULT_CHANNEL=stdout

MARKET_DATA_REST_BOOTSTRAP_BARS=500
MARKET_DATA_SYNC_BATCH_SIZE=500
MARKET_DATA_STALE_AFTER_SECONDS=180
MARKET_DATA_CHECKPOINT_OVERLAP_BARS=1

MONEY_FLOW_STRATEGY_ENABLED=true
MONEY_FLOW_15M_MIN_HISTORY_BARS=35
MONEY_FLOW_15M_RSI_FLOOR=52
MONEY_FLOW_15M_RSI_CEILING=66
MONEY_FLOW_15M_OVERBOUGHT_RSI=72
MONEY_FLOW_15M_REQUIRE_MACD_CONFIRMATION=true
MONEY_FLOW_15M_ALLOW_PULLBACK_ENTRIES=true
MONEY_FLOW_15M_ALLOW_CONTINUATION_ENTRIES=true
MONEY_FLOW_15M_MAX_EXTENSION_PCT_ABOVE_EMA5=0.018
MONEY_FLOW_15M_TRIM_ON_OVERBOUGHT_RSI=true
MONEY_FLOW_15M_TRIM_RSI=78
MONEY_FLOW_15M_CLOSE_ON_MA_BREAK=true
MONEY_FLOW_15M_CLOSE_ON_MACD_ROLLOVER=true

MONEY_FLOW_1H_MIN_HISTORY_BARS=35
MONEY_FLOW_1H_RSI_FLOOR=50
MONEY_FLOW_1H_RSI_CEILING=68
MONEY_FLOW_1H_OVERBOUGHT_RSI=74
MONEY_FLOW_1H_REQUIRE_MACD_CONFIRMATION=true
MONEY_FLOW_1H_ALLOW_PULLBACK_ENTRIES=true
MONEY_FLOW_1H_ALLOW_CONTINUATION_ENTRIES=true
MONEY_FLOW_1H_MAX_EXTENSION_PCT_ABOVE_EMA5=0.02
MONEY_FLOW_1H_TRIM_ON_OVERBOUGHT_RSI=true
MONEY_FLOW_1H_TRIM_RSI=80
MONEY_FLOW_1H_CLOSE_ON_MA_BREAK=true
MONEY_FLOW_1H_CLOSE_ON_MACD_ROLLOVER=true

MONEY_FLOW_4H_MIN_HISTORY_BARS=40
MONEY_FLOW_4H_RSI_FLOOR=48
MONEY_FLOW_4H_RSI_CEILING=70
MONEY_FLOW_4H_OVERBOUGHT_RSI=76
MONEY_FLOW_4H_REQUIRE_MACD_CONFIRMATION=true
MONEY_FLOW_4H_ALLOW_PULLBACK_ENTRIES=true
MONEY_FLOW_4H_ALLOW_CONTINUATION_ENTRIES=true
MONEY_FLOW_4H_MAX_EXTENSION_PCT_ABOVE_EMA5=0.025
MONEY_FLOW_4H_TRIM_ON_OVERBOUGHT_RSI=true
MONEY_FLOW_4H_TRIM_RSI=82
MONEY_FLOW_4H_CLOSE_ON_MA_BREAK=true
MONEY_FLOW_4H_CLOSE_ON_MACD_ROLLOVER=true

# Money Flow still uses family-specific sleeve IDs for its current components.
SLEEVE_15M_ENABLED=true
SLEEVE_15M_TIMEFRAME=15m
SLEEVE_15M_CAPITAL_ALLOCATION_PCT=0.34
SLEEVE_15M_MAX_OPEN_RISK_PCT=0.02

SLEEVE_1H_ENABLED=true
SLEEVE_1H_TIMEFRAME=1h
SLEEVE_1H_CAPITAL_ALLOCATION_PCT=0.33
SLEEVE_1H_MAX_OPEN_RISK_PCT=0.02

SLEEVE_4H_ENABLED=true
SLEEVE_4H_TIMEFRAME=4h
SLEEVE_4H_CAPITAL_ALLOCATION_PCT=0.33
SLEEVE_4H_MAX_OPEN_RISK_PCT=0.02
